{
  "expo": {
    "name": "Pachamama",
    "slug": "Lima",
    "scheme": "pachamama",
    "version": "21.0",
    "orientation": "portrait",
    "icon": "./assets/logofull.jpeg",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/logofull.jpeg",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "bundleIdentifier": "com.pachamama.app",
      "googleServicesFile": "./GoogleService-Info.plist",
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSMicrophoneUsageDescription": "Se necesita el micrófono para las llamadas de voz y video.",
        "NSCameraUsageDescription": "Se necesita la cámara para las videollamadas."
      },
      "icon": "./assets/logofull.jpeg",
      "splash": {
        "image": "./assets/logofull.jpeg",
        "resizeMode": "contain",
        "backgroundColor": "#ffffff"
      }
    },
    "android": {
      "softwareKeyboardLayoutMode": "resize",
      "package": "com.pachamama.app",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/logofull.jpeg",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.BLUETOOTH",
        "android.permission.READ_PHONE_STATE"
      ],
      "intentFilters": [
        {
          "action": "android.intent.action.VIEW",
          "data": {
            "scheme": "https",
            "host": "tiendamas.vip",
            "pathPrefix": "/@"
          },
          "category": [
            "android.intent.category.DEFAULT",
            "android.intent.category.BROWSABLE"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/logofull.jpeg"
    },
    "deeplinks": {
      "urls": [
        "pachamama://anfitriona/:username",
        "https://tiendamas.vip/@:username"
      ]
    },
    "scheme": "pachamama",
    "plugins": [
      "expo-dev-client",
      "expo-router",
      "expo-web-browser",
      "expo-secure-store",
      "expo-video",
      "@react-native-firebase/app",
      "@react-native-firebase/messaging",
      "@react-native-google-signin/google-signin"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8489ade4-9f38-475a-9814-edf6cc88c89c"
      }
    },
    "owner": "jhaseftsaat"
  }
}
