{
  "expo": {
    "name": "MonetizaLab",
    "slug": "Lima",
    "scheme": "pachamama",
    "version": "27.0",
    "orientation": "portrait",
    "icon": "./assets/monetizaicon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/logoMonetizaLab.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "bundleIdentifier": "com.pachamama.app",
      "googleServicesFile": "./GoogleService-Info.plist",
      "supportsTablet": true,
      "associatedDomains": ["applinks:monetizalab.vip"],
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSMicrophoneUsageDescription": "Se necesita el micrófono para las llamadas de voz y video.",
        "NSCameraUsageDescription": "Se necesita la cámara para las videollamadas."
      },
      "icon": "./assets/monetizaicon.png",
      "splash": {
        "image": "./assets/logoMonetizaLab.png",
        "resizeMode": "contain",
        "backgroundColor": "#ffffff"
      }
    },
    "android": {
      "softwareKeyboardLayoutMode": "resize",
      "package": "com.pachamama.app",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/monetizaicon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.BLUETOOTH",
        "android.permission.READ_PHONE_STATE"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "monetizalab.vip",
              "pathPrefix": "/@"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "favicon": "./assets/logoMonetizaLab.png"
    },
    "plugins": [
      "expo-dev-client",
      "expo-router",
      "expo-web-browser",
      "expo-secure-store",
      "expo-video",
      "@react-native-firebase/app",
      "@react-native-firebase/messaging",
      "@react-native-google-signin/google-signin"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "bcc1d0f3-e302-43b6-a649-4a70db602a36"
      }
    },
    "owner": "luigi777"
  }
}
