{
  "expo": {
    "name": "Pachamama",
    "slug": "Lima",
    "scheme": "pachamama",
    "version": "4.0",
    "orientation": "portrait",
    "icon": "./assets/logofull.jpeg",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/logofull.jpeg",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "bundleIdentifier": "com.pachamama.app",
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "icon": "./assets/logofull.jpeg",
      "splash": {
        "image": "./assets/logofull.jpeg",
        "resizeMode": "contain",
        "backgroundColor": "#ffffff"
      }
    },
    "android": {
      "softwareKeyboardLayoutMode": "resize",
      "package": "com.pachamama.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/logofull.jpeg",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/logofull.jpeg"
    },
    "plugins": [
      "expo-dev-client",
      "expo-router",
      "expo-web-browser",
      "expo-secure-store",
      "expo-video"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c896182e-bb15-4c0e-96ca-1037184c0576"
      }
    },
    "owner": "jhaseft"
  }
}
